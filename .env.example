# ============================================
# Environment Variables for Restaurant POS Backend
# ============================================
# Copy these and set in Eclipse Run Config or OS env vars
# DO NOT commit actual values to Git

# ===== Database (REQUIRED) =====
DB_URL=jdbc:mysql://localhost:3306/restaurant_pos?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ===== JWT (REQUIRED) =====
# IMPORTANT: Use a long random string in production. Min 32 characters.
JWT_SECRET=your_long_secret_key_here_minimum_32_characters
JWT_EXPIRATION_MS=86400000

# ===== File Upload (Optional) =====
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE_MB=5

# ===== Server (Optional) =====
SERVER_PORT=8080